# Application
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret

# Database (REQUIRED in production — set via Railway PostgreSQL plugin)
# Railway automatically sets DATABASE_URL when PostgreSQL is attached.
DATABASE_URL=postgresql://user:password@localhost:5432/financecalculator

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Redis (set via Railway Redis plugin if used)
REDIS_URL=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@financecalculator.com

# Sentry
SENTRY_DSN=

# CORS
CORS_ORIGINS=["*"]
